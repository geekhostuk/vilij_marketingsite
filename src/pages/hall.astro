---
// The Vilij — Vilij Hall page
// Imported from Claude Design project "Webpage creation request" (Vilij Hall.dc.html)
const monthlyPrice = "£10";
const showSecondTestimonial = true;

const testimonials = [
  {
    quote:
      "Lorem ipsum doloramet, consectetuer adipiscin sed diam nonumy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi minim veniam, quis nostrud exerci tation",
    name: "Robert & Ethan",
    role: "SEND Grandparent, Bristol",
    photo: "/assets/p_jose.png",
  },
  {
    quote:
      "Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat wisi enim ad minim veniam.",
    name: "Margaret & Charlie",
    role: "SEND Family, Leeds",
    photo: "/assets/p_grand.png",
  },
];

const list = showSecondTestimonial ? testimonials : [testimonials[0]];
const first = list[0];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Vilij — Welcome to the Vilij Hall</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Mulish:wght@400;500;600;700;800&family=Caveat:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      body { margin: 0; }
      * { box-sizing: border-box; }
      .vlink:hover { color: #f28121 !important; }
      .vpill:hover { filter: brightness(1.05); }
      .vcard { transition: transform .25s ease, box-shadow .25s ease; }
      .vcard:hover { transform: translateY(-6px); box-shadow: 0 18px 40px rgba(40,80,90,0.16) !important; }
      .vnav-cta:hover { background: #15838a !important; }
    </style>
  </head>
  <body>
    <div style="font-family:Mulish,sans-serif;color:#353535;background:#ffffff;width:100%;overflow-x:hidden;">

      <!-- ===== HEADER + HERO ===== -->
      <section style="position:relative;background:linear-gradient(100deg,#dbeef1 0%,#e7eef0 38%,#f5e9dc 72%,#fbe1cd 100%);">
        <div style="max-width:1240px;margin:0 auto;padding:30px 48px 0;">
          <nav style="display:flex;align-items:center;justify-content:space-between;">
            <a href="/"><img src="/assets/logo.png" alt="The Vilij" style="height:62px;width:auto;display:block;" /></a>
            <div style="display:flex;align-items:center;gap:42px;">
              <a href="/" class="vlink" style="font-family:Quicksand;font-weight:700;font-size:18px;color:#1f9ca0;text-decoration:none;">Home</a>
              <a href="#" class="vlink" style="font-family:Quicksand;font-weight:600;font-size:18px;color:#1f9ca0;text-decoration:none;">Explore The Vilij</a>
              <a href="#" class="vlink" style="font-family:Quicksand;font-weight:600;font-size:18px;color:#1f9ca0;text-decoration:none;">About Us</a>
              <a href="#" class="vnav-cta vpill" style="font-family:Quicksand;font-weight:700;font-size:16px;letter-spacing:.5px;color:#ffffff;background:#1f9ca0;padding:13px 30px;border-radius:30px;text-decoration:none;box-shadow:0 6px 16px rgba(31,156,160,0.3);">SIGN UP</a>
            </div>
          </nav>
          <div style="display:grid;grid-template-columns:1fr 1.05fr;gap:30px;align-items:center;padding:54px 0 70px;">
            <div>
              <h1 style="font-family:Quicksand;font-weight:700;font-size:74px;line-height:1.04;color:#1f9ca0;margin:0 0 30px;letter-spacing:-1px;">Welcome to<br />the Vilij Hall</h1>
              <p style="font-family:Mulish;font-weight:800;font-size:23px;line-height:1.4;color:#353535;margin:0 0 22px;max-width:520px;">Where stories are shared, voices are heard, and support comes to life.</p>
              <p style="font-family:Mulish;font-size:19px;line-height:1.55;color:#444;margin:0;max-width:520px;">The Vilij Hall is the heart of the Vilij. A welcoming space designed to reduce isolation, build belonging, and remind every SEND parent that you are not alone.</p>
            </div>
            <div style="display:flex;justify-content:center;">
              <div style="width:100%;max-width:600px;border-radius:26px;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);padding:20px 18px 0;box-shadow:0 16px 38px rgba(40,80,90,0.12);">
                <img src="/assets/hall_trim.png" alt="The Vilij Hall" style="width:100%;display:block;border-radius:14px;-webkit-mask-image:linear-gradient(to bottom,#000 88%,transparent 100%);mask-image:linear-gradient(to bottom,#000 88%,transparent 100%);" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== STAY AS LONG BAND ===== -->
      <div style="background:#f28121;text-align:center;padding:26px 24px;">
        <p style="font-family:Quicksand;font-weight:500;font-size:36px;color:#ffe9d6;margin:0;">Stay as long as you like, the doors are always open.</p>
      </div>

      <!-- ===== WHY THE VILIJ HALL EXISTS ===== -->
      <section style="background:#ffffff;padding:90px 0 30px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;">
          <div style="border-radius:26px;background:linear-gradient(90deg,#f6c79a 0%,#fbe5d1 26%,#ffffff 50%,#cfeae8 74%,#a4dbd7 100%);padding:50px 40px 56px;text-align:center;box-shadow:0 14px 36px rgba(40,80,90,0.08);">
            <h2 style="font-family:Quicksand;font-weight:700;font-size:50px;color:#1f9ca0;margin:0 0 26px;">Why The Vilij Hall Exists</h2>
            <p style="font-family:Mulish;font-weight:800;font-size:23px;line-height:1.5;color:#222;margin:0 auto 28px;max-width:760px;">As SEND families we often feel exhausted, invisible, and overwhelmed.</p>
            <p style="font-family:Mulish;font-size:21px;color:#2a2a2a;margin:0 0 22px;">The Vilij Hall gives us:</p>
            <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:14px 40px;font-family:Mulish;font-size:20px;color:#2a2a2a;">
              <span>&bull;&nbsp; A place to breathe.</span>
              <span>&bull;&nbsp; A safe emotional space.</span>
              <span>&bull;&nbsp; A community without judgement.</span>
              <span>&bull;&nbsp; A sense of belonging.</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== FEATURE CARDS ===== -->
      <section style="background:#ffffff;padding:58px 0 80px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr 1fr;gap:60px 44px;">

          <!-- Collective wins (orange, sticky note top-left) -->
          <div style="position:relative;background:#f28121;border-radius:22px;display:flex;gap:24px;padding:34px 36px;min-height:330px;">
            <div style="flex:0 0 40%;display:flex;align-items:flex-start;">
              <div style="background:#fbf3bf;border-radius:6px;padding:22px 20px 28px;margin-top:-56px;margin-left:-12px;box-shadow:0 14px 26px rgba(0,0,0,0.18);transform:rotate(-4deg);width:100%;">
                <p style="font-family:Caveat;font-weight:600;font-size:27px;line-height:1.25;color:#2a2a2a;margin:0;">Today my son Adam, 9, picked up a pencil and scribbled for the first time!</p>
                <div style="text-align:center;font-size:22px;color:#222;margin-top:6px;">&#9825;</div>
              </div>
            </div>
            <div style="flex:1;">
              <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 16px;line-height:1.0;">Collective wins</h3>
              <p style="font-family:Mulish;font-weight:800;font-size:21px;color:#fff;margin:0 0 12px;">Our emotional heartbeat</p>
              <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:rgba(255,255,255,0.96);margin:0;">A place to share and celebrate your victories, big and small, with a SEND community that truly gets it.</p>
            </div>
          </div>

          <!-- Our Stories (teal, photo top-right) -->
          <div style="position:relative;background:#1f9ca0;border-radius:22px;padding:34px 36px;min-height:330px;">
            <div style="display:flex;gap:18px;align-items:flex-start;">
              <div style="flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 16px;line-height:1.0;">Our Stories</h3>
                <p style="font-family:Mulish;font-weight:800;font-size:21px;color:#fff;margin:0;line-height:1.25;">Stories from<br />our Vilijers</p>
              </div>
              <img src="/assets/p_brew.png" alt="Vilijers in conversation" style="flex:0 0 46%;height:170px;object-fit:cover;margin-top:-30px;margin-right:-22px;border-radius:14px;box-shadow:0 14px 28px rgba(0,0,0,0.18);" />
            </div>
            <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:rgba(255,255,255,0.96);margin:24px 0 0;">Real conversations with parents, grandparents, siblings, and carers living the SEND life, sharing their journeys, hopes and lessons.</p>
          </div>

          <!-- Come and meet (teal, photo right) -->
          <div style="position:relative;background:#1f9ca0;border-radius:22px;display:flex;align-items:center;gap:22px;padding:34px 0 34px 36px;min-height:330px;">
            <div style="flex:1;">
              <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 16px;line-height:1.02;">Come<br />and meet</h3>
              <p style="font-family:Mulish;font-weight:800;font-size:21px;color:#fff;margin:0 0 14px;line-height:1.25;">Guidance you<br />can trust</p>
              <p style="font-family:Mulish;font-size:17px;line-height:1.5;color:rgba(255,255,255,0.96);margin:0;">Trusted voices. Real stories. Practical guidance. Meet the experts, parents and people helping to make life feel a little less overwhelming and a lot less lonely.</p>
            </div>
            <img src="/assets/charlie.png" alt="Meet the people of the Vilij" style="flex:0 0 42%;height:280px;object-fit:cover;margin-right:-22px;border-radius:14px;box-shadow:0 14px 28px rgba(0,0,0,0.18);" />
          </div>

          <!-- What's on? (orange, events photo bottom-right) -->
          <div style="position:relative;background:#f28121;border-radius:22px;padding:34px 36px;min-height:330px;overflow:hidden;">
            <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 18px;line-height:1.0;">What&rsquo;s on?</h3>
            <p style="font-family:Mulish;font-weight:800;font-size:21px;color:#fff;margin:0 0 16px;line-height:1.25;max-width:48%;">Find the latest<br />Events here.</p>
            <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:rgba(255,255,255,0.96);margin:0;max-width:48%;">National and local SEND events held online and face to face</p>
            <div style="position:absolute;right:-14px;bottom:-14px;width:48%;height:200px;border-radius:14px;background:repeating-linear-gradient(45deg,#d96e15,#d96e15 12px,#cf6712 12px,#cf6712 24px);box-shadow:0 14px 28px rgba(0,0,0,0.2);display:flex;align-items:center;justify-content:center;">
              <span style="font-family:'Courier New',monospace;font-size:13px;color:rgba(255,255,255,0.92);text-align:center;letter-spacing:.5px;">events<br />signpost photo</span>
            </div>
          </div>

          <!-- Vilij News (orange, photo left) -->
          <div style="position:relative;background:#f28121;border-radius:22px;display:flex;align-items:center;gap:24px;padding:34px 36px 34px 0;min-height:300px;">
            <img src="/assets/p_grand.png" alt="Vilij founders" style="flex:0 0 44%;height:250px;object-fit:cover;margin-left:-22px;border-radius:14px;box-shadow:0 14px 28px rgba(0,0,0,0.18);" />
            <div style="flex:1;">
              <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 18px;line-height:1.02;">Vilij<br />News</h3>
              <p style="font-family:Mulish;font-size:18px;line-height:1.55;color:rgba(255,255,255,0.96);margin:0;">Vilij updates &amp; news from our founders Charlie &amp; Steph</p>
            </div>
          </div>

          <!-- Daily Chat (teal, photo right) -->
          <div style="position:relative;background:#1f9ca0;border-radius:22px;display:flex;align-items:center;gap:22px;padding:34px 0 34px 36px;min-height:300px;">
            <div style="flex:1;">
              <h3 style="font-family:Quicksand;font-weight:700;font-size:42px;color:#fff;margin:0 0 16px;line-height:1.02;">Daily<br />Chat</h3>
              <p style="font-family:Mulish;font-weight:800;font-size:21px;color:#fff;margin:0;line-height:1.25;">Today&rsquo;s<br />Conversations</p>
            </div>
            <img src="/assets/p_elder.png" alt="Daily conversations" style="flex:0 0 46%;height:250px;object-fit:cover;margin-right:-22px;border-radius:14px;box-shadow:0 14px 28px rgba(0,0,0,0.18);" />
          </div>

        </div>
      </section>

      <!-- ===== BE MORE BAR ===== -->
      <div style="background:#2bbfba;">
        <div style="max-width:1240px;margin:0 auto;padding:30px 48px;display:flex;justify-content:space-around;align-items:center;gap:20px;">
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be More</span>
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be Brave</span>
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be Curious</span>
        </div>
      </div>

      <!-- ===== WHAT ELSE INSIDE THE VILIJ ===== -->
      <section style="background:#ffffff;padding:84px 0 90px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;">
          <h2 style="font-family:Quicksand;font-weight:700;font-size:44px;color:#1f9ca0;text-align:center;margin:0 0 14px;">What else you can see inside the Vilij</h2>
          <p style="font-family:Mulish;font-size:20px;color:#444;text-align:center;margin:0 0 54px;">Take a look at the other areas of The Vilij and find out why it&rsquo;s such a special place for SEND families.</p>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;">

            <!-- Café -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/cafe.png" alt="Café" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">CAF&Eacute;</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Pull up a chair, pour a brew and find your people.</p>
                <a href="/cafe" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE CAF&Eacute;?</a>
              </div>
            </div>

            <!-- Beach photo -->
            <div style="border-radius:18px;overflow:hidden;box-shadow:0 10px 28px rgba(40,80,90,0.12);align-self:start;">
              <img src="/assets/p_beach.png" alt="Child at the beach" style="width:100%;height:auto;display:block;" />
            </div>

            <!-- Library -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/library.png" alt="Library" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">LIBRARY</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Practical resources at your fingertips, ready whenever you are.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S IN THE LIBRARY?</a>
              </div>
            </div>

            <!-- Wellbeing -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/wellbeing.png" alt="Wellbeing Centre" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">WELLBEING CENTRE</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Because caring for them starts with caring for you.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE WELL BEING CENTRE?</a>
              </div>
            </div>

            <!-- Market Place -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/market.png" alt="Market Place" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">MARKET PLACE</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Discover wonderful products &amp; services created by S.E.N.D. parents in business.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE MARKET PLACE?</a>
              </div>
            </div>

            <!-- Expert Hub -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/experthub.png" alt="Vilij Expert Hub" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">VILIJ EXPERT HUB</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Trusted experts, tailored advise, and tools that make a difference.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S IN THE EXPERT HUB?</a>
              </div>
            </div>

            <!-- High Street -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/highstreet.png" alt="High Street" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">HIGH STREET</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Handpicked products for S.E.N.D families, all in one easy place.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON THE HIGH STREET?</a>
              </div>
            </div>

            <!-- Family photo -->
            <div style="border-radius:18px;overflow:hidden;box-shadow:0 10px 28px rgba(40,80,90,0.12);align-self:start;">
              <img src="/assets/p_jose.png" alt="A SEND family" style="width:100%;height:auto;display:block;" />
            </div>

            <!-- Vilij Campus -->
