    <script define:vars={{ list }}>
      (function () {
        let t = 0;
        const photo = document.getElementById("t-photo");
        const quote = document.getElementById("t-quote");
        const name = document.getElementById("t-name");
        const role = document.getElementById("t-role");

        function render() {
          const i = ((t % list.length) + list.length) % list.length;
          const cur = list[i];
          if (photo) { photo.src = cur.photo; photo.alt = cur.name; }
          if (quote) quote.textContent = cur.quote;
          if (name) name.textContent = cur.name;
          if (role) role.textContent = cur.role;
        }

        const prev = document.getElementById("t-prev");
        const next = document.getElementById("t-next");
        if (prev) prev.addEventListener("click", function (e) { e.preventDefault(); t -= 1; render(); });
        if (next) next.addEventListener("click", function (e) { e.preventDefault(); t += 1; render(); });

        const toTop = document.getElementById("to-top");
        if (toTop) toTop.addEventListener("click", function (e) { e.preventDefault(); window.scrollTo({ top: 0, behavior: "smooth" }); });

        render();
      })();
    </script>
