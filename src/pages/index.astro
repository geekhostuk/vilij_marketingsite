---
// The Vilij — Homepage
// Imported from Claude Design project "Webpage creation request" (Vilij Homepage.dc.html)
// Configurable props from the original design component:
const monthlyPrice = "£10";
const showSecondTestimonial = true;

const testimonials = [
  {
    quote:
      "Lorem ipsum doloramet, consectetuer adipiscin sed diam nonumy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi minim veniam, quis nostrud exerci tation",
    name: "Jennifer, Tom & Jack",
    role: "SEND Family, York",
    photo: "/assets/testimonial.png",
  },
  {
    quote:
      "Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat wisi enim ad minim veniam.",
    name: "Charlie & Family",
    role: "SEND Family, The Vilij",
    photo: "/assets/charlie.png",
  },
];

const list = showSecondTestimonial ? testimonials : [testimonials[0]];
const first = list[0];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Vilij — You were never meant to do this alone</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Mulish:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      body { margin: 0; }
      * { box-sizing: border-box; }
      .vlink:hover { color: #f28121 !important; }
      .vpill:hover { filter: brightness(1.05); }
      .vcard { transition: transform .25s ease, box-shadow .25s ease; }
      .vcard:hover { transform: translateY(-6px); box-shadow: 0 18px 40px rgba(40,80,90,0.16) !important; }
      .vnav-cta:hover { background: #15838a !important; }
    </style>
  </head>
  <body>
    <div style="font-family:Mulish,sans-serif;color:#353535;background:#ffffff;width:100%;overflow-x:hidden;">

      <!-- ===== HEADER + HERO ===== -->
      <section style="position:relative;background:linear-gradient(to bottom, rgba(255,255,255,0) 58%, #ffffff 100%), linear-gradient(108deg, #fde7d0 0%, #f6e6d6 42%, #dcecea 74%, #d3edee 100%);">
        <div style="max-width:1240px;margin:0 auto;padding:30px 48px 0;">
          <!-- nav -->
          <nav style="display:flex;align-items:center;justify-content:space-between;">
            <img src="/assets/logo.png" alt="The Vilij" style="height:62px;width:auto;display:block;" />
            <div style="display:flex;align-items:center;gap:42px;">
              <a href="#" class="vlink" style="font-family:Quicksand;font-weight:700;font-size:18px;color:#1f9ca0;text-decoration:none;">Home</a>
              <a href="#" class="vlink" style="font-family:Quicksand;font-weight:600;font-size:18px;color:#1f9ca0;text-decoration:none;">Explore The Vilij</a>
              <a href="#" class="vlink" style="font-family:Quicksand;font-weight:600;font-size:18px;color:#1f9ca0;text-decoration:none;">About Us</a>
              <a href="#" class="vnav-cta vpill" style="font-family:Quicksand;font-weight:700;font-size:16px;letter-spacing:.5px;color:#ffffff;background:#1f9ca0;padding:13px 30px;border-radius:30px;text-decoration:none;box-shadow:0 6px 16px rgba(31,156,160,0.3);">SIGN UP</a>
            </div>
          </nav>
          <!-- hero body -->
          <div style="display:grid;grid-template-columns:1fr 1.05fr;gap:30px;align-items:center;padding:48px 0 90px;">
            <div>
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
                <img src="/assets/houseicon.png" alt="" style="width:30px;height:auto;" />
                <span style="font-family:Mulish;font-size:23px;color:#3a3a3a;">Welcome to The Vilij</span>
              </div>
              <h1 style="font-family:Quicksand;font-weight:700;font-size:74px;line-height:1.04;color:#1f9ca0;margin:0 0 26px;letter-spacing:-1px;">You were never meant to do this alone.</h1>
              <p style="font-family:Mulish;font-weight:700;font-size:23px;line-height:1.4;color:#353535;margin:0 0 22px;max-width:560px;">Raising a child with additional needs can be overwhelming - even when you&rsquo;re coping.</p>
              <p style="font-family:Mulish;font-size:19px;line-height:1.55;color:#444;margin:0 0 18px;max-width:560px;">The Vilij is a calm, kind place for SEND families - where you&rsquo;re understood without needing to explain, guided without judgement, and supported by people who actually get it.</p>
              <p style="font-family:Mulish;font-size:19px;line-height:1.55;color:#444;margin:0;max-width:560px;">Think of us as your online village community.</p>
            </div>
            <div style="display:flex;justify-content:center;">
              <img src="/assets/hero_village.png" alt="The Vilij village" style="width:100%;max-width:620px;height:auto;display:block;" />
            </div>
          </div>
        </div>
      </section>

      <!-- ===== BE MORE BAR ===== -->
      <div style="background:#2bbfba;">
        <div style="max-width:1240px;margin:0 auto;padding:30px 48px;display:flex;justify-content:space-around;align-items:center;gap:20px;">
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be More</span>
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be Brave</span>
          <span style="font-family:Quicksand;font-weight:600;font-size:42px;color:#ffffff;">Be Curious</span>
        </div>
      </div>

      <!-- ===== EVERYTHING YOU NEED ===== -->
      <section style="background:#ffffff;padding:84px 0 90px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;">
          <h2 style="font-family:Quicksand;font-weight:700;font-size:54px;color:#1f9ca0;text-align:center;margin:0 0 50px;">Everything you need, in one place.</h2>
          <!-- 5 features -->
          <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:24px;margin-bottom:64px;text-align:center;">
            <div><p style="font-family:Mulish;font-size:18px;line-height:1.45;margin:0;color:#353535;"><strong style="color:#f28121;font-weight:800;">Real-life community spaces</strong> where you&rsquo;re seen, not judged</p></div>
            <div><p style="font-family:Mulish;font-size:18px;line-height:1.45;margin:0;color:#353535;"><strong style="color:#f28121;font-weight:800;">Expert-led guidance</strong> on education, health, EHCPs &amp; benefits</p></div>
            <div><p style="font-family:Mulish;font-size:18px;line-height:1.45;margin:0;color:#353535;"><strong style="color:#f28121;font-weight:800;">Lived-experience wisdom</strong> that makes everything feel more human</p></div>
            <div><p style="font-family:Mulish;font-size:18px;line-height:1.45;margin:0;color:#353535;"><strong style="color:#f28121;font-weight:800;">Bite-size resources</strong> you can use even on the hardest days</p></div>
            <div><p style="font-family:Mulish;font-size:18px;line-height:1.45;margin:0;color:#353535;"><strong style="color:#f28121;font-weight:800;">Wellbeing support</strong> that helps you breathe again</p></div>
          </div>
          <!-- cards grid -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;">

            <!-- Café -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/cafe.png" alt="Café" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">CAF&Eacute;</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Pull up a chair, pour a brew and find your people.</p>
                <a href="/cafe" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE CAF&Eacute;?</a>
              </div>
            </div>

            <!-- Vilij Hall -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/hall.png" alt="Vilij Hall" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">VILIJ HALL</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Where stories are shared, voices are heard, and support comes to life.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON IN THE VILIJ HALL?</a>
              </div>
            </div>

            <!-- Library -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/library.png" alt="Library" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">LIBRARY</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Practical resources at your fingertips, ready whenever you are.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S IN THE LIBRARY?</a>
              </div>
            </div>

            <!-- Wellbeing -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/wellbeing.png" alt="Wellbeing Centre" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">WELLBEING CENTRE</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Because caring for them starts with caring for you.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE WELL BEING CENTRE?</a>
              </div>
            </div>

            <!-- Village illustration (no card) -->
            <div style="display:flex;align-items:center;justify-content:center;padding:10px;">
              <img src="/assets/village_sm.png" alt="The Vilij community" style="width:100%;height:auto;display:block;" />
            </div>

            <!-- Expert Hub -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/experthub.png" alt="Vilij Expert Hub" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">VILIJ EXPERT HUB</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Trusted experts, tailored advise, and tools that make a difference.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S IN THE EXPERT HUB?</a>
              </div>
            </div>

            <!-- High Street -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/highstreet.png" alt="High Street" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">HIGH STREET</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Handpicked products for S.E.N.D families, all in one easy place.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON THE HIGH STREET?</a>
              </div>
            </div>

            <!-- Market Place -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/market.png" alt="Market Place" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">MARKET PLACE</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">Discover wonderful products &amp; services created by S.E.N.D. parents in business.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S ON AT THE MARKET PLACE?</a>
              </div>
            </div>

            <!-- Vilij Campus -->
            <div class="vcard" style="border-radius:18px;overflow:hidden;background:linear-gradient(135deg,#fde7d0 0%,#f3e6d9 46%,#dcebe9 72%,#d3edee 100%);box-shadow:0 10px 28px rgba(40,80,90,0.09);display:flex;flex-direction:column;">
              <div style="padding:14px 8px 0;"><img src="/assets/campus.png" alt="Vilij Campus" style="width:100%;display:block;-webkit-mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);mask-image:linear-gradient(to bottom,#000 84%,transparent 100%);" /></div>
              <div style="padding:6px 30px 30px;display:flex;flex-direction:column;flex:1;">
                <h3 style="font-family:Quicksand;font-weight:700;font-size:25px;color:#1f9ca0;margin:0 0 10px;letter-spacing:.4px;">VILIJ CAMPUS</h3>
                <p style="font-family:Mulish;font-size:18px;line-height:1.5;color:#3a3a3a;margin:0 0 22px;flex:1;">New exciting development now under construction.</p>
                <a href="#" class="vpill" style="align-self:flex-start;font-family:Mulish;font-weight:700;font-size:14px;letter-spacing:.4px;color:#fff;background:#f28121;padding:12px 24px;border-radius:26px;text-decoration:none;box-shadow:0 6px 14px rgba(242,129,33,0.3);">WHAT&rsquo;S COMING TO THE VIJIL CAMPUS?</a>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ===== APP SIGNUP ORANGE BAND ===== -->
      <section style="background:#f28121;text-align:center;padding:62px 24px;">
        <p style="font-family:Mulish;font-size:20px;color:#ffe6cf;margin:0 0 8px;">So what do I do next?</p>
        <h2 style="font-family:Quicksand;font-weight:700;font-size:58px;color:#ffffff;margin:0 0 14px;">Sign up to The Vilij App.</h2>
        <p style="font-family:Mulish;font-size:22px;color:#fff;margin:0 0 34px;">Everything SEND in one place for just {monthlyPrice} per month.</p>
        <a href="#" class="vpill" style="display:inline-flex;align-items:center;gap:16px;background:#ffffff;color:#1f9ca0;font-family:Quicksand;font-weight:700;font-size:19px;letter-spacing:.5px;padding:14px 16px 14px 34px;border-radius:34px;text-decoration:none;box-shadow:0 10px 24px rgba(0,0,0,0.12);">JOIN US NOW <span style="width:40px;height:40px;border-radius:50%;background:#1f9ca0;display:inline-flex;align-items:center;justify-content:center;"><span style="width:0;height:0;border-left:11px solid #fff;border-top:7px solid transparent;border-bottom:7px solid transparent;margin-left:3px;"></span></span></a>
      </section>

      <!-- ===== STILL NOT SURE TEAL BAND ===== -->
      <section style="background:#1f9ca0;padding:30px 24px;">
        <div style="display:flex;align-items:center;justify-content:center;gap:34px;flex-wrap:wrap;">
          <span style="font-family:Quicksand;font-weight:500;font-size:34px;color:#d7f0f0;">Still not sure?</span>
          <a href="#" class="vpill" style="display:inline-flex;align-items:center;gap:14px;background:#f28121;color:#fff;font-family:Quicksand;font-weight:700;font-size:18px;letter-spacing:.5px;padding:12px 14px 12px 30px;border-radius:32px;text-decoration:none;box-shadow:0 8px 20px rgba(0,0,0,0.15);">TAKE A SNEAKY PEEK <span style="width:38px;height:38px;border-radius:50%;background:#ffffff;display:inline-flex;align-items:center;justify-content:center;"><span style="width:0;height:0;border-left:10px solid #1f9ca0;border-top:6px solid transparent;border-bottom:6px solid transparent;margin-left:3px;"></span></span></a>
        </div>
      </section>

      <!-- ===== BENEFITS PANEL ===== -->
      <section style="background:#ffffff;padding:80px 0 30px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;">
          <div style="border-radius:26px;background:linear-gradient(108deg,#fde7d0 0%,#f6e6d6 40%,#dcecea 74%,#d3edee 100%);padding:54px 56px;display:grid;grid-template-columns:repeat(3,1fr);gap:46px;box-shadow:0 14px 36px rgba(40,80,90,0.08);">
            <div>
              <h3 style="font-family:Quicksand;font-weight:700;font-size:30px;color:#1f9ca0;margin:0 0 16px;line-height:1.15;">Community that understands</h3>
              <p style="font-family:Mulish;font-size:18px;line-height:1.55;color:#3a3a3a;margin:0;">A safe, judgement-free space where you don&rsquo;t have to perform or pretend. Just real people who get it.</p>
            </div>
            <div>
              <h3 style="font-family:Quicksand;font-weight:700;font-size:30px;color:#1f9ca0;margin:0 0 16px;line-height:1.15;">Experts on your side</h3>
              <p style="font-family:Mulish;font-size:18px;line-height:1.55;color:#3a3a3a;margin:0;">Clear, calm guidance for EHCPs, school battles, transitions, therapies and everything in between.</p>
            </div>
            <div>
              <h3 style="font-family:Quicksand;font-weight:700;font-size:30px;color:#1f9ca0;margin:0 0 16px;line-height:1.15;">Wellbeing support</h3>
              <p style="font-family:Mulish;font-size:18px;line-height:1.55;color:#3a3a3a;margin:0;">Let us help you breathe again.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== BUILT BY FAMILIES ===== -->
      <section style="background:#ffffff;padding:56px 0 80px;">
        <div style="max-width:1240px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1.15fr 1fr;gap:56px;align-items:start;">
          <div>
            <p style="font-family:Mulish;font-size:22px;color:#3a3a3a;margin:0 0 10px;">How We Can Support You</p>
            <h2 style="font-family:Quicksand;font-weight:700;font-size:56px;line-height:1.05;color:#f28121;margin:0 0 28px;">Built by families who live this life.</h2>
            <p style="font-family:Mulish;font-weight:700;font-size:20px;line-height:1.5;color:#353535;margin:0 0 18px;">We know the fierce love we feel for our children and the exhaustion that comes from battling systems just to secure the life they deserve.</p>
            <p style="font-family:Mulish;font-size:19px;line-height:1.55;color:#444;margin:0 0 16px;">We know the late-night Googling, the meetings, the advocacy, and the moments that feel overwhelming, lonely, and frightened. Many of us have sat in hospital corridors, school meetings, and waiting rooms wondering if anyone else understands this life.</p>
            <p style="font-family:Mulish;font-size:19px;line-height:1.55;color:#444;margin:0 0 16px;">We&rsquo;ve been there. We&rsquo;ve felt it all. And we believe no family should have to navigate it alone.</p>
            <p style="font-family:Mulish;font-weight:700;font-size:20px;line-height:1.5;color:#353535;margin:0;">The Vilij is where you find your people.</p>
